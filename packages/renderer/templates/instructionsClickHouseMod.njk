{% extends "layout.njk" %}
{% import "macros.njk" as macros %}

{% block main %}
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
pub mod {{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row;
{% endfor %}
{% if hasAnchorEvents %}
pub mod cpi_event_row;
{% endif %}

{% for instruction in instructionsToExport | sort(false, false, 'name') %}
pub use self::{{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::*;
{% endfor %}
{% if hasAnchorEvents %}
pub use self::cpi_event_row::*;
{% endif %}

use std::time::Duration;

use carbon_core::{
    clickhouse::{
        rows::{ClickHouseRow, ClickHouseRowContext, ClickHouseRows},
        ClickHouseAdmin, ClickHouseConfig, ClickHouseInstructionProcessor, ClickHouseSchema,
    },
    error::CarbonResult,
    instruction::InstructionMetadata,
};
use solana_instruction::AccountMeta;

use super::{{ program.name | pascalCase }}Instruction;

pub const DEFAULT_DATABASE: &str = "default";
pub const DEFAULT_SOURCE_NAME: &str = "block_crawler";
pub const DEFAULT_MODE: &str = "backfill";
pub const DEFAULT_DECODER_VERSION: &str = "v1";
pub const DEFAULT_MAX_ROWS: usize = 500;
pub const DEFAULT_FLUSH_INTERVAL_MS: u64 = 1_000;

#[derive(Debug, Clone, serde::Serialize)]
#[serde(untagged)]
pub enum {{ program.name | pascalCase }}ClickHouseInstructionRow {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
    {{ instruction.name | pascalCase }}({{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::{{ instruction.name | pascalCase }}InstructionClickHouseRow),
{% endfor %}
{% if hasAnchorEvents %}
    CpiEvent(cpi_event_row::{{ program.name | pascalCase }}CpiEventClickHouseRow),
{% endif %}
}

impl ClickHouseRow for {{ program.name | pascalCase }}ClickHouseInstructionRow {
    fn table_name(&self) -> &'static str {
        match self {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
            Self::{{ instruction.name | pascalCase }}(row) => row.table_name(),
{% endfor %}
{% if hasAnchorEvents %}
            Self::CpiEvent(row) => row.table_name(),
{% endif %}
        }
    }

    fn partition_key(&self) -> String {
        match self {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
            Self::{{ instruction.name | pascalCase }}(row) => row.partition_key(),
{% endfor %}
{% if hasAnchorEvents %}
            Self::CpiEvent(row) => row.partition_key(),
{% endif %}
        }
    }
}

pub type {{ program.name | pascalCase }}ClickHouseInstructionProcessor = ClickHouseInstructionProcessor<
    {{ program.name | pascalCase }}Instruction,
    {{ program.name | pascalCase }}InstructionWithClickHouseMetadata,
    {{ program.name | pascalCase }}ClickHouseInstructionRow,
>;

pub struct {{ program.name | pascalCase }}ClickHouseInstructionsMigration;

impl ClickHouseSchema for {{ program.name | pascalCase }}ClickHouseInstructionsMigration {
    fn operations(_config: &ClickHouseConfig) -> Vec<String> {
        let mut operations = Vec::new();
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
        operations.extend({{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::{{ instruction.name | pascalCase }}InstructionClickHouseRow::migration_operations({{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::{{ instruction.name | pascalCase }}InstructionClickHouseRow::DEFAULT_TABLE_NAME));
{% endfor %}
{% if hasAnchorEvents %}
        operations.extend(cpi_event_row::{{ program.name | pascalCase }}CpiEventClickHouseRow::migration_operations(cpi_event_row::{{ program.name | pascalCase }}CpiEventClickHouseRow::DEFAULT_TABLE_NAME));
{% endif %}
        operations
    }
}

impl {{ program.name | pascalCase }}ClickHouseInstructionsMigration {
    pub async fn run(config: &ClickHouseConfig) -> CarbonResult<()> {
        ClickHouseAdmin::new(config.clone())
            .execute_schema::<Self>()
            .await
    }
}

pub struct {{ program.name | pascalCase }}InstructionWithClickHouseMetadata(
    pub {{ program.name | pascalCase }}Instruction,
    pub InstructionMetadata,
    pub Vec<AccountMeta>,
);

impl From<({{ program.name | pascalCase }}Instruction, InstructionMetadata, Vec<AccountMeta>)>
    for {{ program.name | pascalCase }}InstructionWithClickHouseMetadata
{
    fn from(value: ({{ program.name | pascalCase }}Instruction, InstructionMetadata, Vec<AccountMeta>)) -> Self {
        Self(value.0, value.1, value.2)
    }
}

impl ClickHouseRows<{{ program.name | pascalCase }}ClickHouseInstructionRow>
    for {{ program.name | pascalCase }}InstructionWithClickHouseMetadata
{
    fn clickhouse_rows(&self, context: &ClickHouseRowContext) -> Vec<{{ program.name | pascalCase }}ClickHouseInstructionRow> {
        let {{ program.name | pascalCase }}InstructionWithClickHouseMetadata(instruction, metadata, _accounts) = self;

        match instruction {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
            {{ program.name | pascalCase }}Instruction::{{ instruction.name | pascalCase }} { data, .. } => {
                vec![{{ program.name | pascalCase }}ClickHouseInstructionRow::{{ instruction.name | pascalCase }}(
                    {{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::{{ instruction.name | pascalCase }}InstructionClickHouseRow::from_parts(
                        data.clone(),
                        metadata,
                        context,
                    ),
                )]
            }
{% endfor %}
{% if hasAnchorEvents %}
            {{ program.name | pascalCase }}Instruction::CpiEvent { data, .. } => match data {
{% for event in events | sort(false, false, 'name') %}
                super::CpiEvent::{{ event.name | pascalCase }}(event) => {
                    vec![{{ program.name | pascalCase }}ClickHouseInstructionRow::CpiEvent(
                        cpi_event_row::{{ program.name | pascalCase }}CpiEventClickHouseRow::from_{{ macros.escapeRustKeyword(event.name | snakeCase) }}(
                            event,
                            metadata,
                            context,
                        ),
                    )]
                }
{% endfor %}
            },
{% endif %}
        }
    }
}

pub fn clickhouse_config_from_database_url(database_url: &str) -> CarbonResult<ClickHouseConfig> {
    ClickHouseConfig::from_database_url(
        database_url,
        DEFAULT_DATABASE.to_string(),
{% if instructionsToExport.length > 0 %}
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
{% if loop.first %}
        {{ macros.escapeRustKeyword(instruction.name | snakeCase) }}_row::{{ instruction.name | pascalCase }}InstructionClickHouseRow::DEFAULT_TABLE_NAME.to_string(),
{% endif %}
{% endfor %}
{% else %}
        cpi_event_row::{{ program.name | pascalCase }}CpiEventClickHouseRow::DEFAULT_TABLE_NAME.to_string(),
{% endif %}
        DEFAULT_SOURCE_NAME.to_string(),
        DEFAULT_MODE.to_string(),
        DEFAULT_DECODER_VERSION.to_string(),
        DEFAULT_MAX_ROWS,
        Duration::from_millis(DEFAULT_FLUSH_INTERVAL_MS),
    )
}

pub async fn bootstrap_clickhouse_from_database_url(database_url: &str) -> CarbonResult<ClickHouseConfig> {
    let config = clickhouse_config_from_database_url(database_url)?;
    {{ program.name | pascalCase }}ClickHouseInstructionsMigration::run(&config).await?;
    Ok(config)
}

pub fn clickhouse_processor(config: ClickHouseConfig) -> {{ program.name | pascalCase }}ClickHouseInstructionProcessor {
    ClickHouseInstructionProcessor::new(config)
}

pub async fn setup_clickhouse(database_url: &str) -> CarbonResult<{{ program.name | pascalCase }}ClickHouseInstructionProcessor> {
    let config = bootstrap_clickhouse_from_database_url(database_url).await?;
    Ok(clickhouse_processor(config))
}
{% endblock %}
