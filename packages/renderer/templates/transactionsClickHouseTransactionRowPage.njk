{% extends "layout.njk" %}
{% import "macros.njk" as macros %}

{% block main %}
use std::sync::Arc;

use carbon_core::{
    clickhouse::rows::{
        deterministic_transaction_id, ClickHouseRow, ClickHouseRowContext, ClickHouseRows,
        ClickHouseTable,
    },
    collection::InstructionDecoderCollection,
    instruction::{InstructionDecoder, InstructionMetadata},
    transaction::TransactionMetadata,
};
use chrono::{DateTime, Utc};

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, serde::Serialize)]
pub enum {{ program.name | pascalCase }}ClickHouseInstructionKind {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
    {{ instruction.name | pascalCase }},
{% endfor %}
{% if hasAnchorEvents %}
{% for event in events | sort(false, false, 'name') %}
    {{ event.name | pascalCase }}CpiEvent,
{% endfor %}
{% endif %}
}

#[derive(Debug, Clone, PartialEq, Eq, Hash, serde::Serialize)]
pub struct {{ program.name | pascalCase }}ClickHouseInstructionCollection {
    pub kind: {{ program.name | pascalCase }}ClickHouseInstructionKind,
}

impl InstructionDecoderCollection for {{ program.name | pascalCase }}ClickHouseInstructionCollection {
    type InstructionType = {{ program.name | pascalCase }}ClickHouseInstructionKind;

    fn parse_instruction(
        instruction: &solana_instruction::Instruction,
    ) -> Option<Self> {
        let decoder = crate::{{ program.name | pascalCase }}Decoder;
        let decoded = decoder.decode_instruction(instruction)?;
        let kind = match decoded {
{% for instruction in instructionsToExport | sort(false, false, 'name') %}
            crate::instructions::{{ program.name | pascalCase }}Instruction::{{ instruction.name | pascalCase }} { .. } => Self::InstructionType::{{ instruction.name | pascalCase }},
{% endfor %}
{% if hasAnchorEvents %}
            crate::instructions::{{ program.name | pascalCase }}Instruction::CpiEvent { data, .. } => match data {
{% for event in events | sort(false, false, 'name') %}
                crate::instructions::CpiEvent::{{ event.name | pascalCase }}(_) => Self::InstructionType::{{ event.name | pascalCase }}CpiEvent,
{% endfor %}
            },
{% endif %}
        };

        Some(Self { kind })
    }

    fn get_type(&self) -> Self::InstructionType {
        self.kind
    }
}

#[derive(Debug, Clone, serde::Serialize)]
pub struct {{ program.name | pascalCase }}TransactionClickHouseRow {
    pub program_id: String,
    pub family_name: String,
    pub transaction_id: String,
    pub scope: String,
    pub slot: u64,
    pub signature: String,
    pub fee_payer: String,
    pub is_vote: bool,
    pub tx_index: Option<u64>,
    pub block_hash: Option<String>,
    pub chain_time: Option<String>,
    pub partition_time: String,
    pub fee: u64,
    pub status_success: bool,
    pub status_error: Option<String>,
    pub compute_units_consumed: Option<u64>,
    pub cost_units: Option<u64>,
    pub decoded_instruction_count: u64,
    pub instruction_kinds: Vec<{{ program.name | pascalCase }}ClickHouseInstructionKind>,
    pub absolute_paths: Vec<Vec<u8>>,
    pub instruction_indexes: Vec<u32>,
    pub stack_heights: Vec<u32>,
    pub source_name: String,
    pub mode: String,
    pub decoder_version: String,
    pub ingest_ts: String,
}

impl {{ program.name | pascalCase }}TransactionClickHouseRow {
    pub const FAMILY_NAME: &'static str = "{{ program.name | snakeCase }}_transaction";
    pub const SCOPE: &'static str = "{{ program.name | snakeCase }}";
    pub const DEFAULT_TABLE_NAME: &'static str = "{{ program.name | snakeCase }}_transaction_landing";

    pub fn from_parts(
        metadata: &TransactionMetadata,
        instructions: &[(InstructionMetadata, {{ program.name | pascalCase }}ClickHouseInstructionCollection)],
        context: &ClickHouseRowContext,
    ) -> Self {
        Self::from_parts_with_ingest_ts(metadata, instructions, context, Utc::now())
    }

    pub fn from_parts_with_ingest_ts(
        metadata: &TransactionMetadata,
        instructions: &[(InstructionMetadata, {{ program.name | pascalCase }}ClickHouseInstructionCollection)],
        context: &ClickHouseRowContext,
        ingest_ts: DateTime<Utc>,
    ) -> Self {
        let chain_time = metadata
            .block_time
            .and_then(DateTime::<Utc>::from_timestamp_secs);
        let partition_time = chain_time.unwrap_or(ingest_ts);
        let signature = metadata.signature.to_string();
        let (status_success, status_error) = transaction_status_parts(metadata);

        Self {
            program_id: crate::PROGRAM_ID.to_string(),
            family_name: Self::FAMILY_NAME.to_string(),
            transaction_id: deterministic_transaction_id(Self::SCOPE, &signature),
            scope: Self::SCOPE.to_string(),
            slot: metadata.slot,
            signature,
            fee_payer: metadata.fee_payer.to_string(),
            is_vote: metadata.is_vote,
            tx_index: metadata.index,
            block_hash: metadata.block_hash.map(|hash| hash.to_string()),
            chain_time: chain_time.map(format_datetime),
            partition_time: format_datetime(partition_time),
            fee: metadata.meta.fee,
            status_success,
            status_error,
            compute_units_consumed: metadata.meta.compute_units_consumed,
            cost_units: metadata.meta.cost_units,
            decoded_instruction_count: instructions.len() as u64,
            instruction_kinds: instructions.iter().map(|(_, decoded)| decoded.kind).collect(),
            absolute_paths: instructions
                .iter()
                .map(|(instruction_metadata, _)| instruction_metadata.absolute_path.clone())
                .collect(),
            instruction_indexes: instructions
                .iter()
                .map(|(instruction_metadata, _)| instruction_metadata.index)
                .collect(),
            stack_heights: instructions
                .iter()
                .map(|(instruction_metadata, _)| instruction_metadata.stack_height)
                .collect(),
            source_name: context.source_name.clone(),
            mode: context.mode.clone(),
            decoder_version: context.decoder_version.clone(),
            ingest_ts: format_datetime(ingest_ts),
        }
    }
}

impl ClickHouseTable for {{ program.name | pascalCase }}TransactionClickHouseRow {
    fn table() -> &'static str {
        Self::DEFAULT_TABLE_NAME
    }

    fn columns() -> Vec<&'static str> {
        vec![
            "program_id",
            "family_name",
            "transaction_id",
            "scope",
            "slot",
            "signature",
            "fee_payer",
            "is_vote",
            "tx_index",
            "block_hash",
            "chain_time",
            "partition_time",
            "fee",
            "status_success",
            "status_error",
            "compute_units_consumed",
            "cost_units",
            "decoded_instruction_count",
            "instruction_kinds",
            "absolute_paths",
            "instruction_indexes",
            "stack_heights",
            "source_name",
            "mode",
            "decoder_version",
            "ingest_ts",
        ]
    }

    fn create_table_sql(table_name: &str) -> String {
        format!(
            "CREATE TABLE IF NOT EXISTS {table_name} (\
            program_id String,\
            family_name String,\
            transaction_id String,\
            scope String,\
            slot UInt64,\
            signature String,\
            fee_payer String,\
            is_vote Bool,\
            tx_index Nullable(UInt64),\
            block_hash Nullable(String),\
            chain_time Nullable(DateTime64(3, 'UTC')),\
            partition_time DateTime64(3, 'UTC'),\
            fee UInt64,\
            status_success Bool,\
            status_error Nullable(String),\
            compute_units_consumed Nullable(UInt64),\
            cost_units Nullable(UInt64),\
            decoded_instruction_count UInt64,\
            instruction_kinds Array({}),\
            absolute_paths Array(Array(UInt8)),\
            instruction_indexes Array(UInt32),\
            stack_heights Array(UInt32),\
            source_name String,\
            mode String,\
            decoder_version String,\
            ingest_ts DateTime64(3, 'UTC')\
        ) ENGINE = MergeTree \
        PARTITION BY toYear(partition_time) \
        ORDER BY (program_id, family_name, transaction_id, slot)",
            instruction_kind_clickhouse_type(),
        )
    }
}

impl ClickHouseRow for {{ program.name | pascalCase }}TransactionClickHouseRow {
    fn table_name(&self) -> &'static str {
        Self::table()
    }

    fn partition_key(&self) -> String {
        self.partition_time[..4].to_string()
    }
}

pub struct {{ program.name | pascalCase }}TransactionWithClickHouseMetadata(
    pub Arc<TransactionMetadata>,
    pub Vec<(InstructionMetadata, {{ program.name | pascalCase }}ClickHouseInstructionCollection)>,
);

impl From<(
    Arc<TransactionMetadata>,
    Vec<(InstructionMetadata, {{ program.name | pascalCase }}ClickHouseInstructionCollection)>,
)> for {{ program.name | pascalCase }}TransactionWithClickHouseMetadata
{
    fn from(
        value: (
            Arc<TransactionMetadata>,
            Vec<(InstructionMetadata, {{ program.name | pascalCase }}ClickHouseInstructionCollection)>,
        ),
    ) -> Self {
        Self(value.0, value.1)
    }
}

impl ClickHouseRows<{{ program.name | pascalCase }}TransactionClickHouseRow>
    for {{ program.name | pascalCase }}TransactionWithClickHouseMetadata
{
    fn clickhouse_rows(
        &self,
        context: &ClickHouseRowContext,
    ) -> Vec<{{ program.name | pascalCase }}TransactionClickHouseRow> {
        let Self(metadata, instructions) = self;
        if instructions.is_empty() {
            return Vec::new();
        }

        vec![{{ program.name | pascalCase }}TransactionClickHouseRow::from_parts(
            metadata,
            instructions,
            context,
        )]
    }
}

fn instruction_kind_clickhouse_type() -> &'static str {
    "Enum16({% for instruction in instructionsToExport | sort(false, false, 'name') %}'{{ instruction.name | pascalCase }}' = {{ loop.index0 }}{% if not loop.last or hasAnchorEvents %}, {% endif %}{% endfor %}{% if hasAnchorEvents %}{% for event in events | sort(false, false, 'name') %}'{{ event.name | pascalCase }}CpiEvent' = {{ loop.index0 + instructionsToExport.length }}{% if not loop.last %}, {% endif %}{% endfor %}{% endif %})"
}

fn transaction_status_parts(metadata: &TransactionMetadata) -> (bool, Option<String>) {
    match &metadata.meta.status {
        Ok(()) => (true, None),
        Err(error) => (false, Some(format!("{error:?}"))),
    }
}

fn format_datetime(value: DateTime<Utc>) -> String {
    value.format("%Y-%m-%d %H:%M:%S%.3f").to_string()
}
