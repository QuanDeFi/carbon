#[derive(Debug, Clone, serde::Serialize)]
pub struct {{ event.name | pascalCase }}EventClickHouseRow {
    pub program_id: String,
    pub family_name: String,
    pub event_type: String,
    pub event_id: String,
    pub slot: u64,
    pub signature: String,
    pub instruction_index: u32,
    pub stack_height: u32,
    pub absolute_path: Vec<u8>,
    pub event_seq: u32,
    pub source_name: String,
    pub mode: String,
    pub decoder_version: String,
    pub ingest_ts: String,
    pub chain_time: Option<String>,
    pub partition_time: String,
    pub block_hash: Option<String>,
    pub tx_index: Option<u64>,
{% for field in flatFields %}
    pub {{ field.column }}: {{ field.rowType }},
{% endfor %}
}

impl {{ event.name | pascalCase }}EventClickHouseRow {
    pub const FAMILY_NAME: &'static str = "{{ program.name | snakeCase }}_{{ event.name | snakeCase }}";
    pub const EVENT_TYPE: &'static str = "{{ event.name | snakeCase }}";
    pub const DEFAULT_TABLE_NAME: &'static str = "{{ program.name | snakeCase }}_{{ event.name | snakeCase }}_landing";

    pub fn from_parts(
        source: crate::events::{{ macros.escapeRustKeyword(event.name | snakeCase) }}::{{ event.name | pascalCase }}Event,
        metadata: &InstructionMetadata,
        context: &ClickHouseRowContext,
    ) -> Self {
        let _ = &source;
        let ingest_ts = Utc::now();
        let chain_time = metadata
            .transaction_metadata
            .block_time
            .and_then(DateTime::<Utc>::from_timestamp_secs);
        let partition_time = chain_time.unwrap_or(ingest_ts);
        let signature = metadata.transaction_metadata.signature.to_string();
        let event_seq = 0u32;

        Self {
            program_id: crate::PROGRAM_ID.to_string(),
            family_name: Self::FAMILY_NAME.to_string(),
            event_type: Self::EVENT_TYPE.to_string(),
            event_id: deterministic_event_id(
                crate::PROGRAM_ID.as_ref(),
                &signature,
                &metadata.absolute_path,
                Self::EVENT_TYPE,
                event_seq,
            ),
            slot: metadata.transaction_metadata.slot,
            signature,
            instruction_index: metadata.index,
            stack_height: metadata.stack_height,
            absolute_path: metadata.absolute_path.clone(),
            event_seq,
            source_name: context.source_name.clone(),
            mode: context.mode.clone(),
            decoder_version: context.decoder_version.clone(),
            ingest_ts: format_datetime(ingest_ts),
            chain_time: chain_time.map(format_datetime),
            partition_time: format_datetime(partition_time),
            block_hash: metadata.transaction_metadata.block_hash.map(|hash| hash.to_string()),
            tx_index: metadata.transaction_metadata.index,
{% for field in flatFields %}
            {{ field.column }}: {{ field.expr }},
{% endfor %}
        }
    }
}

impl ClickHouseTable for {{ event.name | pascalCase }}EventClickHouseRow {
    fn table() -> &'static str {
        Self::DEFAULT_TABLE_NAME
    }

    fn columns() -> Vec<&'static str> {
        vec![
            "program_id",
            "family_name",
            "event_type",
            "event_id",
            "slot",
            "signature",
            "instruction_index",
            "stack_height",
            "absolute_path",
            "event_seq",
            "source_name",
            "mode",
            "decoder_version",
            "ingest_ts",
            "chain_time",
            "partition_time",
            "block_hash",
            "tx_index",
{% for field in flatFields %}
            "{{ field.column }}",
{% endfor %}
        ]
    }

    fn create_table_sql(table_name: &str) -> String {
        let engine = Self::clickhouse_engine(table_name);
        Self::create_table_sql_for(table_name, &engine, {{ "false" if clickHouseDdl.mode == "distributed" else "true" }})
    }

    pub fn migration_operations(table_name: &str) -> Vec<String> {
        let mut operations = Vec::new();
{% if clickHouseDdl.createLocalTable %}
        operations.push(Self::create_local_table_sql(table_name));
        operations.extend(Self::add_local_column_sql(table_name));
{% endif %}
        operations.push(Self::create_table_sql(table_name));
        operations.extend(Self::add_column_sql(table_name));
        operations
    }

{% if clickHouseDdl.createLocalTable %}
    pub fn create_local_table_sql(table_name: &str) -> String {
        let local_table_name = format!("{table_name}{{ clickHouseDdl.localTableSuffix }}");
        let engine = Self::clickhouse_local_engine(&local_table_name);
        Self::create_table_sql_for(&local_table_name, &engine, true)
    }

    pub fn add_local_column_sql(table_name: &str) -> Vec<String> {
        let local_table_name = format!("{table_name}{{ clickHouseDdl.localTableSuffix }}");
        Self::add_column_sql(&local_table_name)
    }

{% endif %}
    pub fn add_column_sql(table_name: &str) -> Vec<String> {
        vec![
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS program_id {{ chType('program_id', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS family_name {{ chType('family_name', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS event_type {{ chType('event_type', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS event_id {{ chType('event_id', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS slot {{ chType('slot', 'UInt64') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS signature {{ chType('signature', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS instruction_index {{ chType('instruction_index', 'UInt32') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS stack_height {{ chType('stack_height', 'UInt32') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS absolute_path {{ chType('absolute_path', 'Array(UInt8)') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS event_seq {{ chType('event_seq', 'UInt32') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS source_name {{ chType('source_name', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS mode {{ chType('mode', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS decoder_version {{ chType('decoder_version', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS ingest_ts {{ chType('ingest_ts', "DateTime64(3, 'UTC')") }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS chain_time {{ chType('chain_time', "Nullable(DateTime64(3, 'UTC'))") }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS partition_time {{ chType('partition_time', "DateTime64(3, 'UTC')") }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS block_hash {{ chType('block_hash', 'Nullable(String)') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS tx_index {{ chType('tx_index', 'Nullable(UInt64)') }}"),
{% for field in flatFields %}
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS {{ field.column }} {{ chType(field.column, field.clickHouseColumnType) }}"),
{% endfor %}
        ]
    }

    fn clickhouse_engine(table_name: &str) -> String {
        format!("{{ clickHouseDdl.engine }}")
    }

{% if clickHouseDdl.createLocalTable %}
    fn clickhouse_local_engine(table_name: &str) -> String {
        format!("{{ clickHouseDdl.localEngine }}")
    }

{% endif %}
    fn create_table_sql_for(table_name: &str, engine: &str, include_merge_tree_clauses: bool) -> String {
        let merge_tree_clauses = if include_merge_tree_clauses {
            "{{ ' PARTITION BY ' + clickHouseDdl.partitionBy + ' ORDER BY ' + clickHouseDdl.orderBy + clickHouseDdl.ttlClause + clickHouseDdl.settingsClause }}"
        } else {
            ""
        };
        format!(
            "CREATE TABLE IF NOT EXISTS {table_name}{{ clickHouseDdl.onClusterClause }} (\
            program_id {{ chType('program_id', 'String') }},\
            family_name {{ chType('family_name', 'String') }},\
            event_type {{ chType('event_type', 'String') }},\
            event_id {{ chType('event_id', 'String') }},\
            slot {{ chType('slot', 'UInt64') }},\
            signature {{ chType('signature', 'String') }},\
            instruction_index {{ chType('instruction_index', 'UInt32') }},\
            stack_height {{ chType('stack_height', 'UInt32') }},\
            absolute_path {{ chType('absolute_path', 'Array(UInt8)') }},\
            event_seq {{ chType('event_seq', 'UInt32') }},\
            source_name {{ chType('source_name', 'String') }},\
            mode {{ chType('mode', 'String') }},\
            decoder_version {{ chType('decoder_version', 'String') }},\
            ingest_ts {{ chType('ingest_ts', "DateTime64(3, 'UTC')") }},\
            chain_time {{ chType('chain_time', "Nullable(DateTime64(3, 'UTC'))") }},\
            partition_time {{ chType('partition_time', "DateTime64(3, 'UTC')") }},\
            block_hash {{ chType('block_hash', 'Nullable(String)') }},\
            tx_index {{ chType('tx_index', 'Nullable(UInt64)') }}{% if flatFields.length > 0 %},{% endif %}\
{% for field in flatFields %}
            {{ field.column }} {{ chType(field.column, field.clickHouseColumnType) }}{% if not loop.last %},{% endif %}\
{% endfor %}
        ) ENGINE = {engine}{merge_tree_clauses}"
        )
    }
}

impl ClickHouseRow for {{ event.name | pascalCase }}EventClickHouseRow {
    fn table_name(&self) -> &'static str {
        Self::table()
    }

    fn partition_key(&self) -> String {
        self.partition_time[..4].to_string()
    }
}

fn format_datetime(value: DateTime<Utc>) -> String {
    value.format("%Y-%m-%d %H:%M:%S%.3f").to_string()
}

#[allow(dead_code)]
fn clickhouse_enum_variant<T>(value: &T) -> String
where
    T: serde::Serialize + std::fmt::Debug + ?Sized,
{
    match serde_json::to_value(value) {
        Ok(serde_json::Value::String(variant)) => variant,
        Ok(serde_json::Value::Object(object)) if object.len() == 1 => {
            object.into_iter().next().map(|(variant, _)| variant).unwrap_or_default()
        }
        _ => clickhouse_debug_variant(value),
    }
}

#[allow(dead_code)]
fn clickhouse_debug_variant<T>(value: &T) -> String
where
    T: std::fmt::Debug + ?Sized,
{
    let debug = format!("{value:?}");
    debug
        .split(|ch: char| ch == '(' || ch == '{' || ch.is_whitespace())
        .next()
        .unwrap_or_default()
        .to_string()
}
