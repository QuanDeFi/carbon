            lamports {{ chType('lamports', 'UInt64') }},\
            owner {{ chType('owner', 'String') }},\
            executable {{ chType('executable', 'Bool') }},\
            rent_epoch {{ chType('rent_epoch', 'UInt64') }},\
{% else %}
            instruction_type {{ chType('instruction_type', 'String') }},\
            instruction_id {{ chType('instruction_id', 'String') }},\
            slot {{ chType('slot', 'UInt64') }},\
            signature {{ chType('signature', 'String') }},\
            instruction_index {{ chType('instruction_index', 'UInt32') }},\
            stack_height {{ chType('stack_height', 'UInt32') }},\
            absolute_path {{ chType('absolute_path', 'Array(UInt8)') }},\
