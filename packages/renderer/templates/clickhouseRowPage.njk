            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS program_id {{ chType('program_id', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS family_name {{ chType('family_name', 'String') }}"),
{% if isAccount %}
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS account_type {{ chType('account_type', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS account_id {{ chType('account_id', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS slot {{ chType('slot', 'UInt64') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS pubkey {{ chType('pubkey', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS transaction_signature {{ chType('transaction_signature', 'Nullable(String)') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS lamports {{ chType('lamports', 'UInt64') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS owner {{ chType('owner', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS executable {{ chType('executable', 'Bool') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS rent_epoch {{ chType('rent_epoch', 'UInt64') }}"),
{% else %}
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS instruction_type {{ chType('instruction_type', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS instruction_id {{ chType('instruction_id', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS slot {{ chType('slot', 'UInt64') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS signature {{ chType('signature', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS instruction_index {{ chType('instruction_index', 'UInt32') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS stack_height {{ chType('stack_height', 'UInt32') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS absolute_path {{ chType('absolute_path', 'Array(UInt8)') }}"),
{% endif %}
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS source_name {{ chType('source_name', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS mode {{ chType('mode', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS decoder_version {{ chType('decoder_version', 'String') }}"),
            format!("ALTER TABLE {table_name}{{ clickHouseDdl.onClusterClause }} ADD COLUMN IF NOT EXISTS ingest_ts {{ chType('ingest_ts', "DateTime64(3, 'UTC')") }}"),
{% if isAccount %}
