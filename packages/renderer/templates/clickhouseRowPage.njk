impl {{ entityName | pascalCase }}{% if isAccount %}Account{% else %}Instruction{% endif %}ClickHouseRow {
    pub fn migration_operations(table_name: &str) -> Vec<String> {
        let mut operations = Vec::new();
{% if clickHouseDdl.createLocalTable %}
        operations.push(Self::create_local_table_sql(table_name));
        operations.extend(Self::add_local_column_sql(table_name));
{% endif %}
        operations.push(Self::create_table_sql(table_name));
        operations.extend(Self::add_column_sql(table_name));
        operations
    }

