impl {{ entityName | pascalCase }}{% if isAccount %}Account{% else %}Instruction{% endif %}ClickHouseRow {
    pub const FAMILY_NAME: &'static str = "{{ program.name | snakeCase }}_{{ entityName | snakeCase }}_{% if isAccount %}account{% else %}instruction{% endif %}";
{% if isAccount %}
    pub const ACCOUNT_TYPE: &'static str = "{{ entityName | snakeCase }}";
    pub const DEFAULT_TABLE_NAME: &'static str = "{{ program.name | snakeCase }}_{{ entityName | snakeCase }}_account_landing";
{% else %}
    pub const INSTRUCTION_TYPE: &'static str = "{{ entityName | snakeCase }}";
    pub const DEFAULT_TABLE_NAME: &'static str = "{{ program.name | snakeCase }}_{{ entityName | snakeCase }}_instruction_landing";
{% endif %}

{% if isAccount %}
    pub fn from_parts(
        source: crate::accounts::{{ macros.escapeRustKeyword(entityName | snakeCase) }}::{{ entityName | pascalCase }},
        decoded_account: &DecodedAccount<crate::accounts::{{ program.name | pascalCase }}Account>,
        metadata: &AccountMetadata,
        context: &ClickHouseRowContext,
    ) -> Self {
        let _ = &source;
        let ingest_ts = Utc::now();
        let partition_slot = metadata.slot / 1_000_000;

        Self {
            program_id: crate::PROGRAM_ID.to_string(),
            family_name: Self::FAMILY_NAME.to_string(),
            account_type: Self::ACCOUNT_TYPE.to_string(),
            account_id: deterministic_account_id(
                crate::PROGRAM_ID.as_ref(),
                metadata.pubkey.as_ref(),
                metadata.slot,
                Self::ACCOUNT_TYPE,
            ),
            slot: metadata.slot,
            pubkey: metadata.pubkey.to_string(),
            transaction_signature: metadata.transaction_signature.as_ref().map(|signature| signature.to_string()),
            lamports: decoded_account.lamports,
            owner: decoded_account.owner.to_string(),
            executable: decoded_account.executable,
            rent_epoch: decoded_account.rent_epoch,
            source_name: context.source_name.clone(),
            mode: context.mode.clone(),
            decoder_version: context.decoder_version.clone(),
            ingest_ts: format_datetime(ingest_ts),
            partition_slot,
{% for field in flatFields %}
            {{ field.column }}: {{ field.expr }},
{% endfor %}
        }
    }
{% else %}
    pub fn from_parts(
        source: crate::instructions::{{ macros.escapeRustKeyword(entityName | snakeCase) }}::{{ entityName | pascalCase }},
        metadata: &InstructionMetadata,
        context: &ClickHouseRowContext,
    ) -> Self {
        let _ = &source;
        let ingest_ts = Utc::now();
        let chain_time = metadata
            .transaction_metadata
            .block_time
            .and_then(DateTime::<Utc>::from_timestamp_secs);
        let partition_time = chain_time.unwrap_or(ingest_ts);
        let signature = metadata.transaction_metadata.signature.to_string();

        Self {
            program_id: crate::PROGRAM_ID.to_string(),
            family_name: Self::FAMILY_NAME.to_string(),
            instruction_type: Self::INSTRUCTION_TYPE.to_string(),
            instruction_id: deterministic_instruction_id(
                crate::PROGRAM_ID.as_ref(),
                &signature,
                &metadata.absolute_path,
                Self::INSTRUCTION_TYPE,
            ),
            slot: metadata.transaction_metadata.slot,
            signature,
            instruction_index: metadata.index,
            stack_height: metadata.stack_height,
            absolute_path: metadata.absolute_path.clone(),
            source_name: context.source_name.clone(),
            mode: context.mode.clone(),
            decoder_version: context.decoder_version.clone(),
            ingest_ts: format_datetime(ingest_ts),
            chain_time: chain_time.map(format_datetime),
            partition_time: format_datetime(partition_time),
            block_hash: metadata.transaction_metadata.block_hash.map(|hash| hash.to_string()),
            tx_index: metadata.transaction_metadata.index,
{% for field in flatFields %}
            {{ field.column }}: {{ field.expr }},
{% endfor %}
        }
    }
{% endif %}
}

