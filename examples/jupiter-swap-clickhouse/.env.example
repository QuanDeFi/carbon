# ClickHouse HTTP endpoint. Use auth in the URL if your local instance needs it.
DATABASE_URL=http://carbon:carbon@localhost:8123

# Solana RPC endpoint used by the block crawler. Use a provider URL from your
# local environment; the public mainnet-beta endpoint is not reliable for this
# bounded smoke test.
RPC_URL=<rpc-url>

# Set both START and END for bounded backfills. Set only START to catch up from
# that slot and then keep following head. Leave both empty for pure head-follow
# mode, which also enables TokenLedger account fetching.
BLOCK_CRAWLER_START_SLOT=
BLOCK_CRAWLER_END_SLOT=
BLOCK_CRAWLER_HEAD_LAG_SLOTS=3

# Carbon Prometheus metrics endpoint.
PROMETHEUS_METRICS_ADDR=0.0.0.0:9464

# Optional ClickHouse async-wait insert mode. Sync is the default.
# CLICKHOUSE_ASYNC_INSERT=false

LOG_LEVEL=info
