# ClickHouse HTTP endpoint. Use auth in the URL if your local instance needs it.
DATABASE_URL=http://localhost:8123

# RPC variant. Requires getProgramAccounts support.
RPC_URL=https://api.mainnet-beta.solana.com

# Helius gPA v2 variant. Use with: --source helius-gpa-v2
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# At least one filter is required. Using both fetches token accounts for one
# owner and one mint. This keeps the example bounded.
# TOKEN_ACCOUNT_OWNER=<wallet-pubkey>
# TOKEN_MINT=<mint-pubkey>

# Optional Helius gPA v2 controls.
# HELIUS_GPA_V2_CHANGED_SINCE_SLOT=
# HELIUS_GPA_V2_PAGE_LIMIT=1000

# Optional ClickHouse async-wait insert mode. Sync is the default.
# CLICKHOUSE_ASYNC_INSERT=false
# CLICKHOUSE_ASYNC_INSERT_BUSY_TIMEOUT_MS=1000
# CLICKHOUSE_ASYNC_INSERT_MAX_DATA_SIZE=
# CLICKHOUSE_ASYNC_INSERT_MAX_QUERY_NUMBER=
# CLICKHOUSE_ASYNC_INSERT_DEDUPLICATE=true

LOG_LEVEL=info
